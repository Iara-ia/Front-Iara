# IARA — Front-Iara (Next.js). Copie para .env.local e ajuste.
# .env.local está no .gitignore e NUNCA é versionado.

# Base da API do Back_Iara.
NEXT_PUBLIC_API_BASE_URL="http://localhost:3333"

# Sessão dev do painel (A2): aponta para o owner do seed do back (id fixo em
# Back_Iara/prisma/seed.ts). Sem isto a API responde 401 e as telas abrem vazias.
# Em produção isto vem do Clerk/Auth.js.
NEXT_PUBLIC_DEV_USER_ID="user_fundador_seed"

NEXT_PUBLIC_APP_NAME="IARA"
